# Copy this file to .env and fill in your values.

FLASK_APP=backend:create_app
FLASK_DEBUG=1

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# PostgreSQL connection string
# Format: postgresql+psycopg://user:password@host:port/dbname
FITNESS_DB_URL=postgresql+psycopg://postgres@localhost:5432/fitnessdb

# Shared secret for the /api/ingest endpoint (Health Auto Export REST automation).
# Configure HAE to send header `X-Ingest-Token: <this value>`.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, /api/ingest rejects all requests (fail closed).
INGEST_TOKEN=change-me
